---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { withBasePath } from '../i18n';
---
<BaseLayout title="奉献" description="支持我们在 Agape Triangle 的使命">
  <Container class="py-14 sm:py-20">
    <SectionTitle eyebrow="GIVE" title="支持我们在 Agape Triangle 的使命" subtitle="谢谢你与我们同工，一同推进福音事工。" />

    <div class="mx-auto mt-12 grid max-w-5xl gap-6 lg:grid-cols-2">
      <section class="rounded-3xl border border-black/10 bg-white/40 p-7 shadow-soft">
        <h3 class="font-serif text-2xl text-ink-950">奉献说明</h3>
        <img
          src={withBasePath('/images/zelle.png')}
          alt="Zelle"
          class="mt-5 w-full rounded-2xl object-contain ring-1 ring-black/10 bg-white p-4"
          loading="lazy"
        />
        <p class="mt-4 text-sm leading-7 text-ink-900/70">
          您可以通过 Zelle 进行线上奉献，扫描上方二维码或点击下方按钮即可。如有其他奉献方式需求，请联系我们。
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a href="https://enroll.zellepay.com/qr-codes?data=ewogICJ0b2tlbiIgOiAicnV0aHp5bkBvdXRsb29rLmNvbSIsCiAgIm5hbWUiIDogIkFHQVBFIFRSSUFOR0xFIENISU5FU0UgQ0hVUkNIIiwKICAiYWN0aW9uIiA6ICJwYXltZW50Igp9" target="_blank" rel="noopener noreferrer" class="rounded-full bg-cinnabar-500 px-6 py-3 text-center text-sm font-medium text-white shadow-soft transition hover:bg-cinnabar-600">通过 Zelle 奉献</a>
          <a href={withBasePath('/contact')} class="rounded-full border border-black/10 bg-white/40 px-6 py-3 text-center text-sm font-medium text-ink-950 transition hover:bg-white/70">咨询奉献方式</a>
        </div>
      </section>

      <section class="rounded-3xl border border-black/10 bg-white/40 p-7 shadow-soft">
        <h3 class="font-serif text-2xl text-ink-950">奉献用途（示例）</h3>
        <ul class="mt-5 list-disc space-y-2 pl-5 text-sm leading-7 text-ink-900/70">
          <li>本地宣教与福音外展</li>
          <li>主日与团契聚会支持</li>
          <li>关怀与牧养事工</li>
          <li>场地与行政开销</li>
        </ul>
      </section>
    </div>
  </Container>
</BaseLayout>
