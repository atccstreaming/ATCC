---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import { getSite } from '../../content/site';

const site = getSite('en');
---
<BaseLayout title="Terms and Conditions" description="Terms of use for the Agape Triangle Chinese Church website">
  <Container class="py-14 sm:py-20">
    <div class="mx-auto max-w-3xl rounded-3xl border border-black/10 bg-white/40 p-7 text-sm leading-7 text-ink-900/70 shadow-soft sm:p-10">
      <h1 class="font-serif text-3xl text-ink-950">Terms and Conditions</h1>
      <p class="mt-2 text-xs text-ink-900/60">Last updated: July 5, 2026</p>

      <p class="mt-6">
        Welcome to the {site.nameEn} website. By using this site, you agree to the following terms.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Purpose of this site</h2>
      <p class="mt-3">
        The content on this website is provided for general information about our church, gatherings, events, and
        ministries. Meeting times and event details may change; please refer to the church's latest announcements.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Content and copyright</h2>
      <p class="mt-3">
        The text, images, and logos on this site belong to {site.nameEn} or are used with permission. You are welcome
        to view and share this content for personal, non-commercial purposes. Please do not use it commercially
        without permission.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">External links</h2>
      <p class="mt-3">
        This site links to third-party websites such as YouTube and Google Maps. These links are provided for
        convenience, and we are not responsible for the content of third-party sites.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Disclaimer</h2>
      <p class="mt-3">
        This website is provided "as is." While we strive to keep information accurate, we make no warranties,
        express or implied, about the completeness, accuracy, or suitability of the content, and we are not liable
        for any loss arising from the use of this site.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Changes to these terms</h2>
      <p class="mt-3">We may update these terms from time to time. The current version will always be posted on this page.</p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Contact us</h2>
      <p class="mt-3">
        If you have any questions about these terms, please email
        <a href={`mailto:${site.email}`} class="font-medium text-cinnabar-600 underline decoration-cinnabar-300 underline-offset-4">{site.email}</a>
        or call <a href={site.phoneHref} class="font-medium text-cinnabar-600 underline decoration-cinnabar-300 underline-offset-4">{site.phoneDisplay}</a>.
      </p>
    </div>
  </Container>
</BaseLayout>
