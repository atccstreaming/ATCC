---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import { getSite } from '../../content/site';

const site = getSite('en');
---
<BaseLayout title="Privacy Policy" description="Privacy policy for the Agape Triangle Chinese Church website">
  <Container class="py-14 sm:py-20">
    <div class="mx-auto max-w-3xl rounded-3xl border border-black/10 bg-white/40 p-7 text-sm leading-7 text-ink-900/70 shadow-soft sm:p-10">
      <h1 class="font-serif text-3xl text-ink-950">Privacy Policy</h1>
      <p class="mt-2 text-xs text-ink-900/60">Last updated: July 5, 2026</p>

      <p class="mt-6">
        This website is maintained by {site.nameEn} to share information about our church, gatherings, and resources.
        We value your privacy. This page explains how visitor information is handled on this site.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Information we collect</h2>
      <p class="mt-3">
        This is a static, informational website. There is no account registration and there are no online forms.
        We do not collect personal information from you when you browse this site.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Cookies and analytics</h2>
      <p class="mt-3">This site does not set cookies and does not use any analytics or advertising trackers.</p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">When you contact us</h2>
      <p class="mt-3">
        If you reach out by email or phone, we use the contact information you provide only to respond to your
        inquiry and communicate about church matters. We do not sell or share your information with third parties.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Giving</h2>
      <p class="mt-3">
        Donations made through Zelle are processed entirely by your bank. This website does not collect, receive,
        or store any of your banking or payment information.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">External links</h2>
      <p class="mt-3">
        This site links to third-party websites such as YouTube and Google Maps. Those sites have their own privacy
        policies, and we are not responsible for their content or privacy practices.
      </p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Changes to this policy</h2>
      <p class="mt-3">We may update this privacy policy from time to time. The current version will always be posted on this page.</p>

      <h2 class="mt-8 font-serif text-xl text-ink-950">Contact us</h2>
      <p class="mt-3">
        If you have any questions about this privacy policy, please email
        <a href={`mailto:${site.email}`} class="font-medium text-cinnabar-600 underline decoration-cinnabar-300 underline-offset-4">{site.email}</a>
        or call <a href={site.phoneHref} class="font-medium text-cinnabar-600 underline decoration-cinnabar-300 underline-offset-4">{site.phoneDisplay}</a>.
      </p>
    </div>
  </Container>
</BaseLayout>
