---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { getSite } from '../../content/site';

const site = getSite('en');
---
<BaseLayout title="Contact" description="Contact Agape Triangle Chinese Church">
  <Container class="py-14 sm:py-20">
    <SectionTitle eyebrow="CONTACT" title="Contact" subtitle="We welcome questions and prayer needs." />

    <div class="mx-auto mt-8 grid max-w-2xl gap-6">
      <section class="rounded-3xl border border-black/10 bg-white/40 p-6 shadow-soft">
        <h3 class="font-serif text-2xl text-ink-950">Church Info</h3>
        <div class="mt-5 space-y-4 text-sm leading-7 text-ink-900/70">
          <div>
            <div class="font-medium text-ink-950">Address</div>
            <a href="https://maps.google.com/?q=8509+Penny+Road,+Raleigh,+NC+27606" target="_blank" rel="noopener noreferrer" class="mt-1 block underline decoration-black/20 underline-offset-4 hover:decoration-black/50">{site.addressFull}</a>
          </div>
          <div>
            <div class="font-medium text-ink-950">Email</div>
            <a class="underline decoration-black/20 underline-offset-4 hover:decoration-black/50" href={`mailto:${site.email}`}>{site.email}</a>
          </div>
          <div>
            <div class="font-medium text-ink-950">Phone</div>
            <a class="underline decoration-black/20 underline-offset-4 hover:decoration-black/50" href={site.phoneHref}>{site.phoneDisplay}</a>
          </div>
        </div>
        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <a href="https://maps.google.com/?q=8509+Penny+Road,+Raleigh,+NC+27606" target="_blank" rel="noopener noreferrer" class="rounded-full bg-ink-950 px-4 py-2.5 text-center text-sm font-medium text-parchment-50 shadow-soft transition hover:bg-ink-900">Open Map</a>
          <a href={site.phoneHref} class="rounded-full border border-black/10 bg-white/40 px-4 py-2.5 text-center text-sm font-medium text-ink-950 transition hover:bg-white/70">Call</a>
          <a href={`mailto:${site.email}`} class="rounded-full border border-black/10 bg-white/40 px-4 py-2.5 text-center text-sm font-medium text-ink-950 transition hover:bg-white/70">Email</a>
        </div>
      </section>
    </div>
  </Container>
</BaseLayout>
