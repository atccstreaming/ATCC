---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { getSundayWorship } from '../content/sermons';

const sundayWorship = getSundayWorship('zh');
---
<BaseLayout title="讲道" description="讲道信息与资源">
  <Container class="py-14 sm:py-20">
    <SectionTitle eyebrow="SERMONS" title="讲道" subtitle="主日崇拜与讲道资源将持续更新。" />

    <div class="mx-auto mt-6 flex max-w-4xl flex-wrap gap-3">
      <a
        href="https://www.youtube.com/@AgapeTriangleChineseChurch"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-cinnabar-500 px-5 py-2.5 text-sm font-medium text-white shadow-soft transition hover:bg-cinnabar-600"
      >
        访问 YouTube 频道
      </a>
    </div>

    <div class="mx-auto mt-12 max-w-4xl">
      <h2 class="font-serif text-3xl text-ink-950">主日崇拜</h2>
      <div class="mt-6 space-y-4">
      {sundayWorship.map((s) => (
        <article class="rounded-3xl border border-black/10 bg-white/40 p-7 shadow-soft">
          <div class="text-xs text-ink-900/60">{s.date}</div>
          <h3 class="mt-2 font-serif text-2xl text-ink-950">{s.title}</h3>
          <p class="mt-4 text-sm leading-7 text-ink-900/70">{s.summary}</p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="inline-flex rounded-full bg-ink-950 px-4 py-2 text-sm font-medium text-parchment-50 transition hover:bg-ink-900">
              完整崇拜录像
            </a>
            {s.clip && (
              <a href={s.clip.url} target="_blank" rel="noopener noreferrer" title={s.clip.title} class="inline-flex rounded-full border border-black/10 bg-white/40 px-4 py-2 text-sm font-medium text-ink-950 transition hover:bg-white/70">
                浓缩短片
              </a>
            )}
          </div>
        </article>
      ))}
      </div>
    </div>
  </Container>
</BaseLayout>
